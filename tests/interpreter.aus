include aunit;
include math;
include sys;
include util;
include inctest;

enum numName {
	one;
	two;
	three;
}

class email {
	public address = "";
	
	public setAddress(string Address) { this.address = Address; }
	public getAddress() { return this.address; }
}

/**
 * User class. This class holds the user information.
 */
class user {
    /**
     * Defines the users first name.
     */
	public firstName = "";

	/**
	 * Defines the users last name.
	 */
	public lastName = "";

	/**
	 * Defines the users email address.
	 */
	public emailAddress = null;

	/**
	 * Default constructor creates a new user object and
	 * also sets a default email object.
	 */
	public user() { this.emailAddress = new email(); }

	/**
	 * Sets the fist and last name with the provided values.
	 * @p First is a string with the first name to set.
	 * @p Last is a string with the last name to set.
	 * @r This object.
	 */
	public setName(string First, string Last) { this.firstName = First; this.lastName = Last; return this; }

	/**
	 * Gets the first and last name divided by a space.
	 * @r A string with with the first and last name.
	 */
	public getName() { return this.firstName + " " + this.lastName; }
}

class car {
    private make = "";

    public setMake(string Make) {
        this.make = Make;
        return this;
    }

    public getMake() { return this.make; }
}

class atest {
	public pub = 'Pub';
	pri = 'Pri';

	private priMeth() { return true; }
	public pubMeth() { return true; }
}

class cont {
	public c = null;
	public cont() { this.c = new atest(); }
}

class dog {
	public breed = "undef";
	public dog(string Breed) { this.breed = Breed; }
}

@Test(name = "Interpreter Tests")
class interpreterTests {
	// public member used for testing
	public member = null;
	
	// access tests
	obj = null;
	
	// Members used for definition testing.
	@Mock
	public mem;
	public memNull = null;
	public memBool = false;
	public memInt = 10;
	public memDouble = 123.456;
	public memString = "hi";
	public memList = ['one', 'two', 'three'];
	public memMap = { 'one' : 1, 'two' : 2, 'three' : 3 };
	public memNestedList = [ 0, 1, { 'one' : 1, 'two' : 2 } ];
	public memNestedMap = { 'one' : 1, 'two' : 2, 'three' : [ 0, 1, 2 ] };
	public memObj = null;
	public en = null;

	// Lang members.
	private tlist = null;
	private tmap = null;
	private dt = null;
	private buff = null;
	private cb = null;

	private cr = null;

	// Util members
	private testStr = "On a long enough timeline, the survival rate for everyone drops to zero.";
	
	/***********************************************************************
	 * Local variable assignments.
	 *********************************************************************/
	@Test(name = "(local assignment) Assign variable null.")
	public assignLocalNull() { var = null; return test.expectNull(var); }

	@Test(name = "(local assignment) Assign variable bool.")
	public assignLocalBool() { var = true; return test.expect(var, true); }

    @Test(name = "(local assignment) Assign variable int.")
	public assignLocalInt() { var = 1; return test.expect(var, 1); }

    @Test(name = "(local assignment) Assign variable double.")
	public assignLocalDouble() { var = 12345.6789; return test.expect(var, 12345.6789); }

    @Test(name = "(local assignment) Assign variable string.")
	public assignLocalString() { var = "hello world"; return test.expect(var, "hello world"); }

    @Test(name = "(local assignment) Assign variable list.")
	public assignLocalList() { var = []; return test.expectList(var); }

    @Test(name = "(local assignment) Assign variable map.")
	public assignLocalMap() { var = {}; return test.expectMap(var); }
	
	/***********************************************************************
	 * Member variable assignments.
	 *********************************************************************/
	@Test(name = "(member assignment) Assign variable null.")
	public assignMemberNull() { this.member = null; return test.expectNull(this.member); }

	@Test(name = "(member assignment) Assign variable bool.")
	public assignMemberBool() { this.member = true; return test.expect(this.member, true); }

	@Test(name = "(member assignment) Assign variable int.")
	public assignMemberInt() { this.member = 1; return test.expect(this.member, 1); }

	@Test(name = "(member assignment) Assign variable double.")
	public assignMemberDouble() { this.member = 12345.6789; return test.expect(this.member, 12345.6789); }

	@Test(name = "(member assignment) Assign variable string.")
	public assignMemberString() { this.member = "hello world"; return test.expect(this.member, "hello world"); }

	@Test(name = "(member assignment) Assign variable list.")
	public assignMemberList() { this.member = []; return test.expectList(this.member); }

	@Test(name = "(member assignment) Assign variable map.")
	public assignMemberMap() { this.member = {}; return test.expectMap(this.member); }
	
	/***********************************************************************
	 * Member variable definitions.
	 *********************************************************************/
	@Test(name = "(member definition) Defined member blank.")
	public defineMemberBlank() { return test.expectNull(this.mem); }

	@Test(name = "(member definition) Defined member null.")
	public defineMemberNull() { return test.expectNull(this.memNull); }

	@Test(name = "(member definition) Defined member bool.")
	public defineMemberBool() { return test.expect(this.memBool, false); }

	@Test(name = "(member definition) Defined member int.")
	public defineMemberInt() { return test.expect(this.memInt, 10); }

	@Test(name = "(member definition) Defined member double.")
	public defineMemberDouble() { return test.expect(this.memDouble, 123.456); }

	@Test(name = "(member definition) Defined member string.")
	public defineMemberString() { return test.expect(this.memString, "hi"); }

	@Test(name = "(member definition) Defined member list.")
	public defineMemberList() { return test.expect(this.memList[2], "three"); }

	@Test(name = "(member definition) Defined member map.")
	public defineMemberMap() { return test.expect(this.memMap['three'], 3); }

	@Test(name = "(member definition) Defined member nested list.")
	public defineMemberListNested() { return test.expect(this.memNestedList[2]['two'], 2); }

	@Test(name = "(member definition) Defined member nested map.")
	public defineMemberMapNested() { return test.expect(this.memNestedMap['three'][2], 2); }
	 
	 /***********************************************************************
	  * Basic operator tests
	  *********************************************************************/
	 // Numeric +
	 @Test(name = "(+ operator) Bool plus bool.")
	 public operBoolPlusBool() { var = true + true; return test.expect(var, 2); }

	 @Test(name = "(+ operator) Bool plus int.")
	 public operBoolPlusInt() { var = true + 5; return test.expect(var, 6); }

	 @Test(name = "(+ operator) Bool plus double.")
	 public operBoolPlusDouble() { var = true + 5.0; return test.expect(var, 6.0); }

	 @Test(name = "(+ operator) Int plus bool.")
	 public operIntPlusBool() { var = 5 + true; return test.expect(var, 6); }

	 @Test(name = "(+ operator) Int plus int.")
	 public operIntPlusInt() { var = 5 + 10; return test.expect(var, 15); }

	 @Test(name = "(+ operator) Int plus double.")
	 public operIntPlusDouble() { var = 5 + 10.0; return test.expect(var, 15.0); }

	 @Test(name = "(+ operator) Double plus bool.")
	 public operDoublePlusBool() { var = 5.0 + true; return test.expect(var, 6.0); }

	 @Test(name = "(+ operator) Double plus int.")
	 public operDoublePlusInt() { var = 5.0 + 10; return test.expect(var, 15.0); }

	 @Test(name = "(+ operator) Double plus double.")
	 public operDoublePlusDouble() { var = 5.0 + 10.0; return test.expect(var, 15.0); }
	 // String +
	 @Test(name = "(+ operator) String plus null.")
	 public operStringPlusNull() { var = "is " + null; return test.expect(var, "is null"); }

	 @Test(name = "(+ operator) String plus bool.")
	 public operStringPlusBool() { var = "is " + true; return test.expect(var, "is true"); }

	 @Test(name = "(+ operator) String plus int.")
	 public operStringPlusInt() { var = "is " + 1; return test.expect(var, "is 1"); }

	 @Test(name = "(+ operator) String plus double.")
	 public operStringPlusDouble() { var = "is " + 123.456; return test.expect(var, "is 123.456"); }

	 @Test(name = "(+ operator) String plus string.")
	 public operStringPlusString() { var = "is " + "string"; return test.expect(var, "is string"); }

	 @Test(name = "(+ operator) Null plus string.")
	 public operNullPlusString() { var = null + " is"; return test.expect(var, "null is"); }

	 @Test(name = "(+ operator) Bool plus string.")
	 public operBoolPlusString() { var = true + " is"; return test.expect(var, "true is"); }

	 @Test(name = "(+ operator) Int plus string.")
	 public operIntPlusString() { var = 1 + " is"; return test.expect(var, "1 is"); }

	 @Test(name = "(+ operator) Double plus string.")
	 public operDoublePlusString() { var = 123.456 + " is"; return test.expect(var, "123.456 is"); }
	 // Numeric -
	 @Test(name = "(- operator) Bool minus bool.")
	 public operBoolMinusBool() { var = true - true; return test.expect(var, 0); }

	 @Test(name = "(- operator) Bool minus int.")
	 public operBoolMinusInt() { var = true - 2; return test.expect(var, -1); }

	 @Test(name = "(- operator) Bool minus double.")
	 public operBoolMinusDouble() { var = true - 2.0; return test.expect(var, -1.0); }

	 @Test(name = "(- operator) Int minus bool.")
	 public operIntMinusBool() { var = 2 - true; return test.expect(var, 1); }

	 @Test(name = "(- operator) Int minus int.")
	 public operIntMinusInt() { var = 2 - 1; return test.expect(var, 1); }

	 @Test(name = "(- operator) Int minus double.")
	 public operIntMinusDouble() { var = 2 - 1.0; return test.expect(var, 1.0); }

	 @Test(name = "(- operator) Double minus bool.")
	 public operDoubleMinusBool() { var = 2.0 - true; return test.expect(var, 1.0); }

	 @Test(name = "(- operator) Double minus int.")
	 public operDoubleMinusInt() { var = 2.0 - 1; return test.expect(var, 1.0); }

	 @Test(name = "(- operator) Double minus double.")
	 public operDoubleMinusDouble() { var = 2.0 - 1.0; return test.expect(var, 1.0); }
	 // Numeric *
	 @Test(name = "(* operator) Bool times bool.")
	 public operBoolTimesBool() { var = true * true; return test.expect(var, 1); }

	 @Test(name = "(* operator) Bool times int.")
	 public operBoolTimesInt() { var = true * 10; return test.expect(var, 10); }

	 @Test(name = "(* operator) Bool times double.")
	 public operBoolTimesDouble() { var = true * 10.0; return test.expect(var, 10.0); }

	 @Test(name = "(* operator) Int times bool.")
	 public operIntTimesBool() { var = 10 * true; return test.expect(var, 10); }

	 @Test(name = "(* operator) Int times int.")
	 public operIntTimesInt() { var = 10 * 2; return test.expect(var, 20); }

	 @Test(name = "(* operator) Int times double.")
	 public operIntTimesDouble() { var = 10 * 2.0; return test.expect(var, 20.0); }

	 @Test(name = "(* operator) Double times bool.")
	 public operDoubleTimesBool() { var = 2.0 * true; return test.expect(var, 2.0); }

	 @Test(name = "(* operator) Double times int.")
	 public operDoubleTimesInt() { var = 2.0 * 2; return test.expect(var, 4.0); }

	 @Test(name = "(* operator) Double times double.")
	 public operDoubleTimesDouble() { var = 2.0 * 2.0; return test.expect(var, 4.0); }
	 // Numeric /
	 @Test(name = "(/ operator) Bool divide bool.")
	 public operBoolDivideBool() { var = true / true; return test.expect(var, 1); }

	 @Test(name = "(/ operator) Bool divide int.")
	 public operBoolDivideInt() { var = true / 1; return test.expect(var, 1); }

	 @Test(name = "(/ operator) Bool divide double.")
	 public operBoolDivideDouble() { var = true / 1.0; return test.expect(var, 1.0); }

	 @Test(name = "(/ operator) Int divide bool.")
	 public operIntDivideBool() { var = 10 / true; return test.expect(var, 10); }

	 @Test(name = "(/ operator) Int divide int.")
	 public operIntDivideInt() { var = 10 / 2; return test.expect(var, 5); }

	 @Test(name = "(/ operator) Int divide double.")
	 public operIntDivideDouble() { var = 10 / 2.0; return test.expect(var, 5.0); }

	 @Test(name = "(/ operator) Double divide bool.")
	 public operDoubleDivideBool() { var = 2.0 / true; return test.expect(var, 2.0); }

	 @Test(name = "(/ operator) Double divide int.")
	 public operDoubleDivideInt() { var = 2.0 / 2; return test.expect(var, 1.0); }

	 @Test(name = "(/ operator) Double divide double.")
	 public operDoubleDivideDouble() { var = 2.0 / 2.0; return test.expect(var, 1.0); }
	 // Numeric %
	 @Test(name = "(% operator) Bool modulus bool.")
	 public operBoolModulusBool() { var = true % true; return test.expect(var, 0.0); }

	 @Test(name = "(% operator) Bool modulus int.")
	 public operBoolModulusInt() { var = true % 1; return test.expect(var, 0.0); }

	 @Test(name = "(% operator) Bool modulus double.")
	 public operBoolModulusDouble() { var = true % 1.0; return test.expect(var, 0.0); }

	 @Test(name = "(% operator) Int modulus bool.")
	 public operIntModulusBool() { var = 10 % true; return test.expect(var, 0.0); }

	 @Test(name = "(% operator) Int modulus int.")
	 public operIntModulusInt() { var = 10 % 4; return test.expect(var, 2); }

	 @Test(name = "(% operator) Int modulus double.")
	 public operIntModulusDouble() { var = 10 % 4.0; return test.expect(var, 2.0); }

	 @Test(name = "(% operator) Double modulus bool.")
	 public operDoubleModulusBool() { var = 2.0 % true; return test.expect(var, 0.0); }

	 @Test(name = "(% operator) Double modulus int.")
	 public operDoubleModulusInt() { var = 2.0 % 2; return test.expect(var, 0.0); }

	 @Test(name = "(% operator) Double modulus double.")
	 public operDoubleModulusDouble() { var = 2.0 % 2.0; return test.expect(var, 0.0); }
	 // Count #
	 @Test(name = "(# operator) Local list count.")
	 public operLocalListCount() { var = []; var @= "Tyler"; return test.expect(#var - 1, 0); }

	 @Test(name = "(# operator) Local map count.")
	 public operLocalMapCount() { var = {}; var['char'] = "Tyler"; return test.expect(#var, 1); }

	 @Test(name = "(# operator) Local map count exception.")
	 public operLocalMapCountException() {
	    thrown = false;
	    var = {};
	    try {
	        // this.pages doesn't exist, this should throw an exception.
	        val = (#var.pages / 3).toInt();
	    } catch (e) {
            thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(# operator) Member list count.")
	 public operMemberListCount() { return test.expect(#this.memList, 3); }

	 @Test(name = "(# operator) Member map count.")
	 public operMemberMapCount() { return test.expect(#this.memMap, 3); }

	 @Test(name = "(# operator) Member map count exception.")
	 public operMemberMapCountException() {
	    thrown = false;
	    try {
	        // this.pages doesn't exist, this should throw an exception.
	        val = (#this.pages / 3).toInt();
	    } catch (e) {
            thrown = true;
	    }
	    return test.expect(thrown, true);
	 }
     // Greater than >
     @Test(name = "(> operator) Greater than bool vals.")
     public operGreaterThanBool() { return test.expect(true > false, true); }

     @Test(name = "(> operator) Greater than int vals.")
     public operGreaterThanInt() { return test.expect(256 > 1, true); }

     @Test(name = "(> operator) Greater than double vals.")
     public operGreaterThanDouble() { return test.expect(3.14157 > 1.2345, true); }

     // Less than <
     @Test(name = "(< operator) Less than bool vals.")
     public operLessThanBool() { return test.expect(true < false, false); }

     @Test(name = "(< operator) Less than int vals.")
     public operLessThanInt() { return test.expect(256 < 1, false); }

     @Test(name = "(< operator) Less than double vals.")
     public operLessThanDouble() { return test.expect(3.14157 < 1.2345, false); }

     // Greater than equal >=
     @Test(name = "(>= operator) Greater than equal to bool vals.")
     public operGreaterThanEqualToBool() { return test.expect(true >= false, true); }

     @Test(name = "(>= operator) Greater than equal to int vals.")
     public operGreaterThanEqualToInt() { return test.expect(256 >= 1, true); }

     @Test(name = "(>= operator) Greater than equal to double vals.")
     public operGreaterThanEqualToDouble() { return test.expect(3.14157 >= 1.2345, true); }

     // Less than equal <=
     @Test(name = "(<= operator) Less than equal to bool vals.")
     public operLessThanEqualToBool() { return test.expect(true <= false, false); }

     @Test(name = "(<= operator) Less than equal to int vals.")
     public operLessThanEqualToInt() { return test.expect(256 <= 1, false); }

     @Test(name = "(<= operator) Less than equal to double vals.")
     public operLessThanEqualToDouble() { return test.expect(3.14157 <= 1.2345, false); }

	 @Test(name = "(&& operator) Both true.")
	 public operAndTrueTrue() { return test.expect(true && true, true); }

	 @Test(name = "(&& operator) Short circuit.")
	 public operAndFalseTrue() { return test.expect(false && true, false); }

	 @Test(name = "(&& operator) Right only.")
	 public operAndTrueFalse() { return test.expect(true && false, false); }

	 @Test(name = "(&& operator) Both false.")
	 public operAndFalseFalse() { return test.expect(false && false, false); }

	 @Test(name = "(|| operator) Both true.")
	 public operOrTrueTrue() { return test.expect(true || true, true); }

	 @Test(name = "(|| operator) Left only.")
	 public operOrFalseTrue() { return test.expect(false || true, true); }

	 @Test(name = "(|| operator) Short circuit.")
	 public operOrTrueFalse() { return test.expect(true || false, true); }

	 @Test(name = "(|| operator) Both false.")
	 public operOrFalseFalse() { return test.expect(false || false, false); }

	 /***********************************************************************
	  * List operations.
	  *********************************************************************/
	 @Test(name = "(list operations) List local append null.")
	 public listLocalAppendNull() { tmp = []; tmp @= null; return test.expectNull(tmp[0]); }

	 @Test(name = "(list operations) List local append bool.")
	 public listLocalAppendBool() { tmp = []; tmp @= true; return test.expect(tmp[0], true); }

	 @Test(name = "(list operations) List local append int.")
	 public listLocalAppendInt() { tmp = []; tmp @= 32; return test.expect(tmp[0], 32); }

	 @Test(name = "(list operations) List local append double.")
	 public listLocalAppendDouble() { tmp = []; tmp @= 3.1514; return test.expect(tmp[0], 3.1514); }

	 @Test(name = "(list operations) List local append string.")
	 public listLocalAppendString() { tmp = []; tmp @= "Tyler"; return test.expect(tmp[0], "Tyler"); }

	 @Test(name = "(list operations) List local append local list.")
	 public listLocalAppendLocalList() { tmp = []; lst = []; lst @= "Tyler"; tmp @= lst; return test.expect(tmp[0][0], "Tyler"); }

	 @Test(name = "(list operations) List local append local map.")
	 public listLocalAppendLocalMap() { tmp = []; mp = {}; mp['char'] = "Tyler"; tmp @= mp; return test.expect(tmp[0]['char'], "Tyler"); }

	 @Test(name = "(list operations) List member append null.")
	 public listMemberAppendNull() { this.memList @= null; return test.expect(this.memList[3], null); }

	 @Test(name = "(list operations) List member append bool.")
	 public listMemberAppendBool() { this.memList @= true; return test.expect(this.memList[4], true); }

	 @Test(name = "(list operations) List member append int.")
	 public listMemberAppendInt() { this.memList @= 32; return test.expect(this.memList[5], 32); }

	 @Test(name = "(list operations) List member append double.")
	 public listMemberAppendDouble() { this.memList @= 3.1415; return test.expect(this.memList[6], 3.1415); }

	 @Test(name = "(list operations) List member append string.")
	 public listMemberAppendString() { this.memList @= "Tyler"; return test.expect(this.memList[7], "Tyler"); }

	 @Test(name = "(list operations) List member append local deref with var.")
	 public listMemberAppendLocalVarRef() { var = 8; this.memList @= "Durden"; return test.expect(this.memList[var], "Durden"); }

	 @Test(name = "(list operations) List local new list.")
	 public listLocalNewList() {
	 	lst = [1, 2, 3, 'four', [1, 2, 3]];
	 	return test.expect(lst[0] == 1 && lst[1] == 2 && lst[2] == 3 && lst[3] == 'four' && lst[4] instanceof 'list', true);
	 }

	 @Test(name = "(list operations) List local get by local var.")
	 public listLocalGetLocalVar() {
	 	lst = ['one', 'two', 'three'];
	 	ind = 1;
	 	return test.expect(lst[ind], 'two');
	 }

	 @Test(name = "(list operations) Ensure exceptions are propagated up.")
	 public listPropagateException() {
	    excaught = false;
	    tobj = {};
	    try {
	        nlist = ['1', 2, tobj.doesntExist];
	    } catch (e) {
	        excaught = true;
	    }
	    return test.expect(excaught, true);
	 }
	 
	 /***********************************************************************
	  * Map operations.
	  *********************************************************************/
	 @Test(name = "(map operations) Map member assign string.")
	 public mapMemberSetString() { this.memMap['name'] = "Tyler"; return test.expect(this.memMap['name'], "Tyler"); }

	 @Test(name = "(map operations) Map member assign local var.")
	 public mapMemberSetLocalVar() {
	 	var = 'lname';
	 	this.memMap[var] = "Durden";
	 	return test.expect(this.memMap[var], "Durden");
	 }

	 @Test(name = "(map operations) Map local set string and assign bool.")
	 public mapLocalSetStringAssignBool() { tmp = {}; tmp['val'] = true; return test.expect(tmp['val'], true); }
	 public mapLocalSetStringReAssignBool() { tmp = {}; tmp['val'] = true; tmp['val'] = false; return test.expect(tmp['val'], false); }

	 @Test(name = "(map operations) Map local set string and assign int.")
	 public mapLocalSetStringAssignInt() { tmp = {}; tmp['val'] = 10; return test.expect(tmp['val'], 10); }

	 @Test(name = "(map operations) Map local set string and assign double.")
	 public mapLocalSetStringAssignDouble() { tmp = {}; tmp['val'] = 123.456; return test.expect(tmp['val'], 123.456); }

	 @Test(name = "(map operations) Map local set string and assign string.")
	 public mapLocalSetStringAssignString() { tmp = {}; tmp['val'] = "test"; return test.expect(tmp['val'], "test"); }

	 @Test(name = "(map operations) Map local set string and assign list.")
	 public mapLocalSetStringAssignList() { tmp = {}; tmp['val'] = []; return test.expectList(tmp['val']); }

	 @Test(name = "(map operations) Map local set string and assign var list.")
	 public mapLocalSetStringAssignVarList() { tmp = {}; lst = []; tmp['val'] = lst; return test.expectList(tmp['val']); }

	 @Test(name = "(map operations) Map local set string and re-assign var list.")
	 public mapLocalSetStringReAssignVarList() { tmp = {}; lst = []; tmp['val'] = lst; tmp['val'] = lst; return test.expectList(tmp['val']); }

	 @Test(name = "(map operations) Map local set string and assign map.")
	 public mapLocalSetStringAssignMap() { tmp = {}; tmp['val'] = {}; return test.expectMap(tmp['val']); }

	 @Test(name = "(map operations) Map local set string and re-assign var list.")
	 public mapLocalSetStringReAssignVarMap() { tmp = {}; tmp['val'] = {}; tmp['val'] = {}; return test.expectMap(tmp['val']); }

	 @Test(name = "(map operations) Map local set object ref and assign string.")
	 public mapLocalObjRefAssignString() {
	 	tobj = new email();
	 	tobj.address = 'name';
	 	tmap = {};
	 	tmap[tobj.address] = 'Tyler';
	 	return test.expect(tmap[tobj.address], 'Tyler');
	 }

	 @Test(name = "(map operations) Map local new map.")
	 public mapLocalNewMap() {
	 	mp = { 'one': 1, 'two': 2, 'three': 3, 'four': 'something' };
	 	return test.expect(mp['one'] == 1 && mp['two'] == 2 && mp['three'] == 3 && mp['four'] == 'something', true);
	 }

	 @Test(name = "(map operations) Map local set/get by local var.")
	 public mapLocalSetGetLocalVar() {
	 	mp = {};
	 	key = 'name';
	 	mp[key] = 'Tyler';
	 	return test.expect(mp[key], 'Tyler');
	 }

	 @Test(name = "(map operations) Ensure exceptions are propagated up.")
	 public mapPropagateException() {
	    excaught = false;
	    tobj = {};
	    try {
	        nmap = { one: '1', two: 2, three: tobj.doesntExist };
	    } catch (e) {
	        excaught = true;
	    }
	    return test.expect(excaught, true);
	 }
	 
	 
	 /***********************************************************************
	  * instanceof operator tests
	  *********************************************************************/
	 @Test(name = "(instanceof operations) Instance of null.")
	 public instanceOfNull() { tmp = null; return test.expect(tmp instanceof 'null', true); }

	 @Test(name = "(instanceof operations) Instance of bool.")
	 public instanceOfBool() { tmp = true; return test.expect(tmp instanceof 'bool', true); }

	 @Test(name = "(instanceof operations) Instance of int.")
	 public instanceOfInt() { tmp = 32; return test.expect(tmp instanceof 'int', true); }

	 @Test(name = "(instanceof operations) Instance of double.")
	 public instanceOfDouble() { tmp = 3.1415; return test.expect(tmp instanceof 'double', true); }

	 @Test(name = "(instanceof operations) Instance of string.")
	 public instanceOfString() { tmp = "Tyler"; return test.expect(tmp instanceof 'string', true); }

	 @Test(name = "(instanceof operations) Instance of list.")
	 public instanceOfList() { tmp = []; return test.expect(tmp instanceof 'list', true); }

	 @Test(name = "(instanceof operations) Instance of map.")
	 public instanceOfMap() { tmp = {}; return test.expect(tmp instanceof 'map', true); }

	 @Test(name = "(instanceof operations) Instance of callback.")
	 public instanceOfCallback() { tmp = ::instanceOfCallback; return test.expect(tmp instanceof 'callback', true); }

	 @Test(name = "(instanceof operations) Object of type user should be of type user.")
	 public instanceOfObjectUser() { usr = new user(); usr.firstName = "Tyler"; usr.lastName = "Durden"; return test.expect(usr instanceof 'user', true); }
	 
