	@Test(name = "(util hex) Encode/Decode hex value.")
	public hexEncodeDecode() {
	    buff = new buffer();
	    buff.addString("Aussom");
	    encodedStr = hex.encode(buff);
	    decodedBuff = hex.decode(encodedStr);
	    return test.expect(decodedBuff.getString().startsWith("Aussom"), true);
	}

    @Test(name = "(util base64) Encode/Decode base64 value.")
    public base64EncodeDecode() {
        buff = new buffer();
        buff.addString("Aussom");
	    encodedStr = base64.encode(buff);
	    decodedBuff = base64.decode(encodedStr);
	    return test.expect(decodedBuff.getString().startsWith("Aussom"), true);
    }

    @Test(name = "(util base64) Encode/Decode raw base64 value.")
