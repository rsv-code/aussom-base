	@Test(name = "(lang string) String last index of.")
	public stringLastIndexOf() { return test.expect("Tyler Durden".lastIndexOf("e"), 10); }

	@Test(name = "(lang string) String last index of start.")
	public stringLastIndexOfStart() { return test.expect("Tyler Durden".lastIndexOfStart("e", 5), 3); }

