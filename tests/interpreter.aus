	 @Test(name = "(object operations) Constructor exception caught by surrounding try/catch.")
	 public objectConstructorExceptionCaught() {
	    thrown = false;
	    try {
	        // The Date(int Mills) constructor delegates to an extern call
	        // that fails when given a non-int. The thrown exception must
	        // be caught by this surrounding try/catch.
	        d = new Date("not_a_date");
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(object operations) Constructor argument expression exception caught by surrounding try/catch.")
	 public objectConstructorArgExceptionCaught() {
	    thrown = false;
	    try {
	        // An expression evaluated for a 'new' argument throws.
	        // The exception must be catchable by the surrounding try/catch.
	        n = new needsArg(throwingHelper.boom());
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(object operations) Instantiating an unknown class caught by surrounding try/catch.")
	 public objectInstantiateUnknownClassCaught() {
	    thrown = false;
	    try {
	        // No class named 'thisClassDoesNotExist' exists. The instantiation
	        // failure must be catchable by the surrounding try/catch.
	        x = new thisClassDoesNotExist();
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(object operations) Inheriting from a missing base class caught by surrounding try/catch.")
	 public objectInheritMissingBaseCaught() {
	    thrown = false;
	    try {
	        // childOfMissing extends a base class that does not exist.
	        // The class-init error must be catchable by the surrounding try/catch.
	        x = new childOfMissing();
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(object operations) reflect.instantiate runs default-parameter constructor.")
	 public reflectInstantiateDefaultParam() {
	    o = reflect.instantiate("reflectInstWithDefault");
	    return test.expect(o.n, 7);
	 }

	 @Test(name = "(object operations) reflect.instantiate constructor body reads local correctly.")
	 public reflectInstantiateReadsLocalInCtor() {
	    o = reflect.instantiate("reflectInstReadsLocal");
	    return test.expect(o.n, 42);
	 }

