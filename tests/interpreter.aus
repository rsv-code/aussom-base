	 @Test(name = "(object operations) Instantiate local object.")
	 public objectInstantiateLocal() { me = new user(); me.setName("Tyler", "Durden"); return test.expect(me.getName(), "Tyler Durden"); }

	 @Test(name = "(object operations) Instantiate member object.")
	 public objectInstantiateMember() { this.memObj = new user(); this.memObj.setName("Tyler", "Durden"); return test.expect(this.memObj.getName(), "Tyler Durden"); }

	 @Test(name = "(object operations) Local object set member.")
	 public objectLocalSetMember() { me = new user(); me.firstName = "Tyler"; return test.expect(me.getName(), "Tyler "); }

	 @Test(name = "(object operations) Member object set member.")
	 public objectMemberSetMember() { this.memObj.firstName = "Austin"; return test.expect(this.memObj.getName(), "Austin Durden"); }

	 @Test(name = "(object operations) Local object set sub member.")
	 public objectLocalSetSubMember() { me = new user(); me.emailAddress.address = "one@two.com"; return test.expect(me.emailAddress.address, "one@two.com"); }

	 @Test(name = "(object operations) Member object set sub member.")
	 public objectMemberSetSubMember() { this.memObj.emailAddress.address = "one@two.com"; return test.expect(this.memObj.emailAddress.address, "one@two.com"); }

	 @Test(name = "(object operations) Local object call sub member.")
	 public objectLocalCallSubMember() { me = new user(); me.emailAddress.setAddress("one@two.com"); return test.expect(me.emailAddress.getAddress(), "one@two.com"); }

	 @Test(name = "(object operations) Member object call sub member.")
	 public objectMemberCallSubMember() { this.memObj.emailAddress.setAddress("one@two.com"); return test.expect(this.memObj.emailAddress.getAddress(), "one@two.com"); }

	 @Test(name = "(object operations) Local object set block.")
	 public objectLocalSetBlock() {
	    me = new user() := {
	        firstName: "Tyler",
	        lastName: "Durden"
	    };
	    return test.expect(me.firstName, "Tyler");
	 }

	 @Test(name = "(object operations) Member object set block.")
	 public objectMemberSetBlock() {
	    this.memObj = new user() := {
	        firstName: "Tyler",
	        lastName: "Durden"
	    };
	    return test.expect(this.memObj.firstName, "Tyler");
	 }

	 @Test(name = "(object operations) Local object set block function.")
	 public objectLocalSetBlockFunction() {
	    cr = new car() := {
	        make: "Nissan"
	    };
	    return test.expect(cr.getMake(), "Nissan");
	 }

	 @Test(name = "(object operations) Member object set block function.")
	 public objectMemberSetBlockFunction() {
	    this.cr = new car() := {
	        make: "Nissan"
	    };
	    return test.expect(this.cr.getMake(), "Nissan");
	 }

	 @Test(name = "(object operations) Local object set block as variable.")
	 public objectLocalSetBlockAsVariable() {
	    mpVal = {
	        make: "Nissan"
	    };
	    cr = new car() := mpVal;
	    return test.expect(cr.getMake(), "Nissan");
	 }

	 @Test(name = "(object operations) Member object set block as variable.")
	 public objectMemberSetBlockAsVariable() {
	    mpVal = {
	        make: "Nissan"
	    };
	    this.cr = new car() := mpVal;
	    return test.expect(this.cr.getMake(), "Nissan");
	 }

	 @Test(name = "(object operations) Local object set block exception.")
	 public objectLocalSetBlockException() {
	    try {
            me = new user() := [
                "Robert"
            ];
            return false;
        } catch (e) {
            return true;
        }
	 }

