	/***********************************************************************
	 * Scientific-notation numeric literals.
	 *
	 * The lexer's number rule accepts an optional [eE][+-]?[0-9]+ exponent.
	 * Any literal containing 'e', 'E', or '.' becomes a DOUBLE token; bare
	 * integers stay INT. Identifiers that happen to start with a letter
	 * (e1, e_value) still tokenize as identifiers.
	 *********************************************************************/

	@Test(name = "(scientific notation) Lower-case e literal.")
	public sciLower() { return test.expect(1e3, 1000.0); }

	@Test(name = "(scientific notation) Upper-case E literal.")
	public sciUpper() { return test.expect(1E3, 1000.0); }

	@Test(name = "(scientific notation) Decimal mantissa with exponent.")
	public sciDecimal() { return test.expect(1.5e2, 150.0); }

	@Test(name = "(scientific notation) Negative exponent.")
	public sciNegExp() { return test.expectClose(1e-4, 0.0001, 1e-9); }

	@Test(name = "(scientific notation) Explicit positive exponent.")
	public sciPosExp() { return test.expect(1e+3, 1000.0); }

	@Test(name = "(scientific notation) Large value.")
	public sciLarge() { return test.expectClose(1.0E30, 1.0E30, 1.0E21); }

	@Test(name = "(scientific notation) Identifier starting with letter still parses.")
	public sciIdentUnaffected() { e1 = 7; return test.expect(e1, 7); }

	/***********************************************************************
	 * String comparison operators (<, >, <=, >=).
	 *
	 * Two AussomString operands are compared lexicographically with
	 * String.compareTo (Unicode code unit order), matching string.compare().
	 * Mixed-type operands still raise INVALID_COMPARISON.
	 *********************************************************************/

	// Less than (<)
	@Test(name = "(string compare) Less than true when left precedes right.")
	public stringLtTrue() { return test.expect("apple" < "banana", true); }

	@Test(name = "(string compare) Less than false when left follows right.")
	public stringLtFalseWhenAfter() { return test.expect("banana" < "apple", false); }

	@Test(name = "(string compare) Less than false when strings are equal.")
	public stringLtFalseWhenEqual() { return test.expect("apple" < "apple", false); }

	@Test(name = "(string compare) Less than orders ISO date strings.")
	public stringLtIsoDates() { return test.expect("2026-01-15" < "2026-04-27", true); }

	@Test(name = "(string compare) Less than treats empty string as smallest.")
	public stringLtEmpty() { return test.expect("" < "a", true); }

	@Test(name = "(string compare) Less than is case sensitive.")
	public stringLtCaseSensitive() { return test.expect("Z" < "a", true); }

	// Greater than (>)
	@Test(name = "(string compare) Greater than true when left follows right.")
	public stringGtTrue() { return test.expect("banana" > "apple", true); }

	@Test(name = "(string compare) Greater than false when left precedes right.")
	public stringGtFalseWhenBefore() { return test.expect("apple" > "banana", false); }

	@Test(name = "(string compare) Greater than false when strings are equal.")
	public stringGtFalseWhenEqual() { return test.expect("apple" > "apple", false); }

	@Test(name = "(string compare) Greater than orders ISO date strings.")
	public stringGtIsoDates() { return test.expect("2026-04-27" > "2026-01-15", true); }

	// Less than or equal (<=)
	@Test(name = "(string compare) Less than equal true when strings are equal.")
	public stringLeTrueWhenEqual() { return test.expect("apple" <= "apple", true); }

	@Test(name = "(string compare) Less than equal true when left precedes right.")
	public stringLeTrueWhenBefore() { return test.expect("apple" <= "banana", true); }

	@Test(name = "(string compare) Less than equal false when left follows right.")
	public stringLeFalseWhenAfter() { return test.expect("banana" <= "apple", false); }

	// Greater than or equal (>=)
	@Test(name = "(string compare) Greater than equal true when strings are equal.")
	public stringGeTrueWhenEqual() { return test.expect("apple" >= "apple", true); }

	@Test(name = "(string compare) Greater than equal true when left follows right.")
	public stringGeTrueWhenAfter() { return test.expect("banana" >= "apple", true); }

	@Test(name = "(string compare) Greater than equal false when left precedes right.")
	public stringGeFalseWhenBefore() { return test.expect("apple" >= "banana", false); }

	// Unicode \uXXXX escape in string literals. The lexer should decode
	// \uXXXX to the matching code point in all string forms. Without the
	// fix the backslash is silently dropped and the literal "u" plus the
	// hex digits stay in the string -- so length and equality assertions
	// against the expected decoded form will fail.
	@Test(name = "(string escape) Unicode \u0041 in double-quote string -> 'A'.")
	public stringEscapeUnicodeDouble() { return test.expect("\u0041", "A"); }

	@Test(name = "(string escape) Unicode \u0061 in double-quote string -> 'a'.")
	public stringEscapeUnicodeDoubleLower() { return test.expect("\u0061", "a"); }

	@Test(name = "(string escape) Unicode \u0041 in single-quote string -> 'A'.")
	public stringEscapeUnicodeSingle() { return test.expect('\u0041', "A"); }

	@Test(name = "(string escape) Unicode \u0041 in triple-quote string -> 'A'.")
	public stringEscapeUnicodeTriple() { return test.expect("""\u0041""", "A"); }

	@Test(name = "(string escape) Multiple unicode escapes -> 'ABC'.")
	public stringEscapeUnicodeMultiple() { return test.expect("\u0041\u0042\u0043", "ABC"); }

	@Test(name = "(string escape) Unicode escape mid-string -> length 4.")
	public stringEscapeUnicodeMidLen() { return test.expect(#"caf\u00e9", 4); }

	@Test(name = "(string escape) Unicode \u2022 (bullet) length 1.")
	public stringEscapeUnicodeBulletLen() { return test.expect(#"\u2022", 1); }

	@Test(name = "(string escape) Unicode escape with surrounding text -> 'Hi!'.")
	public stringEscapeUnicodeSurround() { return test.expect("H\u0069!", "Hi!"); }
	
