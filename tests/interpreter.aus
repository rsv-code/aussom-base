	/*
	 **********************************************************************
	 * json tests
	 *********************************************************************/
	@Test(name = "(lang json) JSON parse string.")
	public jsonParseString() {
		jstr = """
		{
			"firstName": "Tyler",
			"lastName": "Durden",
			"age": 35,
			"pi": 3.1415,
			"vet": true,
			"nextHouse": null,
			"months": ["November", "December", "January"],
			"loc": {
				"latitude": 38.7521,
				"longitude": -121.2880
			}
		}
		""";
		jobj = json.parse(jstr);
		return test.expect(jobj instanceof 'map', true);
	}

	@Test(name = "(lang json) JSON unpack object.")
	public jsonUnpack() {
		jstr = """
			{
				"type":"user",
				"members":{
					"firstName":{
						"type":"string",
						"value":"Tyler"
					},
					"lastName":{
						"type":"string",
						"value":"Durden"
					},
					"emailAddress":{
						"type":"email",
						"members":{
							"address":{
								"type":"string",
								"value":""
							}
						}
					},
					"dob": {
						"type":"Date",
						"value":"2015-01-01T00:00:00.000Z"
					}
				}
			}
		""";
		u = json.unpack(jstr);
		test.expect(u.dob.toString(), '2015-01-01T00:00:00.000Z');
		return test.expect(u instanceof 'user', true);
	}

	@Test(name = "(lang json) JSON escape object string.")
    public jsonEscapeObjectString() {
        jstr = """
        {
            "firstName": "Tyler",
            "lastName": "Durden",
            "age": 35
        }
        """;
        escapedString = json.escape(jstr);
        testStr = "\\n        {\\n            \\\"firstName\\\": \\\"Tyler\\\",\\n            \\\"lastName\\\": \\\"Durden\\\",\\n            \\\"age\\\": 35\\n        }\\n";
        test.expect(escapedString.trim(), testStr);
    }

    @Test(name = "(lang json) JSON escape array string.")
    public jsonEscapeArrayString() {
        jstr = """
        [
            "one",
            "two",
            "three",
            4,
            5,
            6
        ]
        """;
        escapedString = json.escape(jstr);
        testStr = "\\n        [\\n            \\\"one\\\",\\n            \\\"two\\\",\\n            \\\"three\\\",\\n            4,\\n            5,\\n            6\\n        ]\\n";
        test.expect(escapedString.trim(), testStr);
    }

    @Test(name = "(lang json) Pack and unpack JSON string")
    public jsonPackUnpack() {
        bf = new Buffer();
        bf.setString("Hello World");

        info = new Info();
        info.name = "Test";
        info.date = (new Date()).parse("2015-01-01T00:00:00.000Z", "yyyy-MM-dd'T'HH:mm:ss.SSSXXX");
        info.buff = bf;

        packed = info.pack();
        unpacked = json.unpack(packed);

        test.expect(unpacked.date.toString(), "2015-01-01T00:00:00.000Z");
        test.expect(unpacked.buff.getString(), "Hello World");
    }
	
	
