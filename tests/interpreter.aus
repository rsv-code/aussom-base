	@Test(name = "(lang object) Object to JSON.")
	public objectToJson() {
		try {
			u = new user();
			u.setName("Tyler", "Durden");
			return test.expect(u.toJson(), """{"firstName":"Tyler","lastName":"Durden","emailAddress":{"address":""}}""");
		} catch (e) { c.err(e); }
	}

	@Test(name = "(lang object) Object pack.")
	public objectPack() {
		try {
			u = new user();
			u.setName("Tyler", "Durden");
			return test.expect(u.pack(), """{"type":"user","members":{"firstName":{"type":"string","value":"Tyler"},"lastName":{"type":"string","value":"Durden"},"emailAddress":{"type":"email","members":{"address":{"type":"string","value":""}}}}}""");
		} catch (e) { c.err(e); }
	}
	
	/*
	 **********************************************************************
	 * json tests
	 *********************************************************************/
	@Test(name = "(lang json) JSON parse string.")
	public jsonParseString() {
		jstr = """
		{
			"firstName": "Tyler",
			"lastName": "Durden",
			"age": 35,
			"pi": 3.1415,
			"vet": true,
			"nextHouse": null,
			"months": ["November", "December", "January"],
			"loc": {
				"latitude": 38.7521,
				"longitude": -121.2880
			}
		}
		""";
		jobj = json.parse(jstr);
		return test.expect(jobj instanceof 'map', true);
	}

	@Test(name = "(lang json) JSON unpack object.")
	public jsonUnpack() {
		jstr = """
			{
				"type":"user",
				"members":{
					"firstName":{
						"type":"string",
						"value":"Tyler"
					},
					"lastName":{
						"type":"string",
						"value":"Durden"
					},
					"emailAddress":{
						"type":"email",
						"members":{
							"address":{
								"type":"string",
								"value":""
							}
						}
					}
				}
			}
		""";
		u = json.unpack(jstr);
		return test.expect(u instanceof 'user', true);
	}
	
	
