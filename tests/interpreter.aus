	/***********************************************************************
     * mock tests
     *********************************************************************/
    @Test(name = "(mock) Simple function mock test.")
    public simpleMockTest() {
        // Create a new user object.
        u = new user();
        u.firstName = "Austin";

        // Set the simple mock. (funName, retObj)
        u.mock("getName", "Avery");

        // Expect/Assert that the mocked function will return the value we provided.
        test.expect(u.getName(), "Avery");
    }

    @Test(name = "(mock) Mock when test 1.")
    public mockWhenTest1() {
        // Create a new user object.
        u = new user();
        u.firstName = "Tyler";
        u.lastName = "Durden";

        // Set the mock when. (funName, callback, retObj) When the result
        // of the callback is true, it will set to the provided value.
        u.mockWhen("getName", ::onMock1Test, "Bob Durden");
        test.expect(u.getName(), "Bob Durden");

        // Update the first name and then expect it to run without
        // matching the mock when. We should get the function to
        // run normally this time.
        u.firstName = "Fred";
        test.expect(u.getName(), "Fred Durden");
    }

    /**
     * What's provided here are two arguments. The first is the instance
     * of the object itself. The second is the arguments that were
     * provided to the invoking function.
     */
    public onMock1Test(cobj, args) {
        if (cobj.firstName == "Tyler") { return true; }
        return false;
    }

    @Test(name = "(mock) Spy set/get test 1.")
    public mockSpyTest1() {
        u = new user();
        u.setName("Tyler", "Durden");

        // Set the spy.
        u.setSpy("getName");

        // Call the function.
        name = u.getName();
        test.expect(#u.getSpy("getName"), 1);

        name = u.getName();
        test.expect(#u.getSpy("getName"), 2);
    }

    @Test(name = "(mock) Simple function mock test on string object.")
    public simpleStringMockTest() {
        // Create a new string object.
        name = "Tyler Durden";

        // Set the simple mock. (funName, retObj)
        name.mock("toLower", "TYLER DURDEN");

        // Expect/Assert that the mocked function will return the value we provided.
        test.expect(name.toLower(), "TYLER DURDEN");
    }

    /***********************************************************************
     * lexer comment tests
     *********************************************************************/

    // Banner-style block comments must be lexed as plain block comments,
    // not as AUSSOM_DOC. Otherwise a banner followed by a real doc comment
    // emits two AUSSOM_DOC tokens in a row and the parser rejects them.
    // Tests load source via testRunner.loadTestString which throws on
    // parse error; passing means the load succeeded.

    @Test(name = "(lexer comments) Banner divider then real doc comment then class.")
    public lexerBannerThenDocBeforeClass() {
        src = "/*****\n * Section divider\n *****/\n\n/**\n * Real doc comment\n */\nclass lcz { public main() { return 1; } }";
        ok = false;
        try {
            r = new testRunner();
            r.loadTestString("lc_banner_then_doc", src);
            ok = true;
        } catch (e) { ok = false; }
        return test.expect(ok, true);
    }

    @Test(name = "(lexer comments) Two banner dividers in a row before class.")
    public lexerTwoBannersBeforeClass() {
        src = "/*****\n * A\n *****/\n\n/*****\n * B\n *****/\nclass lcw { public main() { return 1; } }";
        ok = false;
        try {
            r = new testRunner();
            r.loadTestString("lc_two_banners", src);
            ok = true;
        } catch (e) { ok = false; }
        return test.expect(ok, true);
    }

    @Test(name = "(lexer comments) Inline four-star divider then real doc comment.")
    public lexerInlineDividerThenDoc() {
        src = "/****/\n\n/**\n * Real doc\n */\nclass lcv { public main() { return 1; } }";
        ok = false;
        try {
            r = new testRunner();
            r.loadTestString("lc_inline_divider", src);
            ok = true;
        } catch (e) { ok = false; }
        return test.expect(ok, true);
    }

    @Test(name = "(lexer comments) Long realistic banner then doc comment.")
    public lexerLongBannerThenDoc() {
        bar = "/******************************************************************\n";
        body = " * Section A: setup helpers\n";
        end = " ******************************************************************/\n";
        doc = "\n/**\n * Sets things up.\n */\n";
        cls = "class lcu { public main() { return 1; } }";
        src = bar + body + end + doc + cls;
        ok = false;
        try {
            r = new testRunner();
            r.loadTestString("lc_long_banner", src);
            ok = true;
        } catch (e) { ok = false; }
        return test.expect(ok, true);
    }

    /***********************************************************************
     * Method overloading by signature.
     *
     * Covers arity overloads, type-discrimination, numeric promotion
     * (int -> double), wildcards (full and partial), specificity,
     * ambiguity policy, variadic dispatch, default arguments, null
     * matching, multi-level inheritance, constructor overloading,
     * per-overload access modifiers, recursive self-calls through
     * overloaded names, mixed wildcard + variadic interaction, and
     * typed-variadic promotion.
     *
     * Negative tests use try/catch to capture exception text.
     * Helper classes are declared at the top of this file.
     *********************************************************************/

    // ---------- Arity overloading ----------

    @Test(name = "(arity) Zero-arg overload selected on no-arg call.")
    public arityZero() {
        s = new shape();
        return test.expect(s.draw(), "no-args");
    }

    @Test(name = "(arity) Two-arg overload selected on 2-arg call.")
    public arityTwo() {
        s = new shape();
        return test.expect(s.draw(1, 2), "two-ints");
    }

    @Test(name = "(arity) Three-arg overload selected on 3-arg call.")
    public arityThree() {
        s = new shape();
        return test.expect(s.draw(1, 2, 3), "three-ints");
    }

    @Test(name = "(arity) Wrong-arity call raises FUNCT_NOT_FOUND.")
    public arityNoMatch() {
        s = new shape();
        ex = "";
        try { s.draw(1, 2, 3, 4); } catch (e) { ex = e.getText(); }
        return test.expect(ex.contains("no overload"), true);
    }

    // ---------- Type-based overloading ----------

    @Test(name = "(types) Int overload selected on int call.")
    public typesInt() {
        l = new location();
        return test.expect(l.set(1, 2), "int-int");
    }

    @Test(name = "(types) Double overload selected on double call.")
    public typesDouble() {
        l = new location();
        return test.expect(l.set(1.0, 2.0), "double-double");
    }

    @Test(name = "(types) String overload selected on string call.")
    public typesString() {
        l = new location();
        return test.expect(l.set("origin"), "string");
    }

    @Test(name = "(types) Single-int overload distinct from two-int.")
    public typesSingleInt() {
        l = new location();
        return test.expect(l.set(42), "int");
    }

    // ---------- Numeric promotion (int -> double) ----------

    @Test(name = "(promotion) Int call promoted to double when no int overload exists.")
    public promotionIntToDouble() {
        p = new promoteOnly();
        return test.expect(p.f(7), "double:7.0");
    }

    @Test(name = "(promotion) Exact int overload beats promoted double.")
    public promotionExactBeats() {
        l = new location();
        return test.expect(l.set(1, 2), "int-int");
    }

    @Test(name = "(promotion) Mixed int/double call promotes int -> double.")
    public promotionMixed() {
        l = new location();
        // (int, double) - no exact overload; one promotion -> "double-double".
        return test.expect(l.set(1, 2.5), "double-double");
    }

    @Test(name = "(promotion) Equally-specific promoted matches raise AMBIGUOUS_OVERLOAD.")
    public promotionAmbiguity() {
        a = new promoteAmbig();
        ex = "";
        try { a.f(1, 2); } catch (e) { ex = e.getText(); }
        return test.expect(ex.contains("ambiguous"), true);
    }

    @Test(name = "(promotion) Double argument does not narrow to int slot.")
    public promotionNoNarrow() {
        // location.set(int, int) and (double, double) exist; (1.5, 2)
        // should promote the int (2 -> 2.0) and resolve to double-double,
        // not narrow 1.5 to an int.
        l = new location();
        return test.expect(l.set(1.5, 2), "double-double");
    }

    @Test(name = "(promotion) All int args promote when only an all-double overload exists.")
    public promotionBothArgs() {
        pb = new promoteBoth();
        return test.expect(pb.f(3, 4), 7.0);
    }

    // ---------- Wildcards ----------

    @Test(name = "(wildcard) Fully-typed beats partial wildcard.")
    public wildcardTypedWins() {
        w = new wildy();
        return test.expect(w.f(1, 2), "ii");
    }

    @Test(name = "(wildcard) Partial wildcard selected when typed slot mismatches.")
    public wildcardPartialFirst() {
        w = new wildy();
        return test.expect(w.f(1, "hi"), "i*");
    }

    @Test(name = "(wildcard) Partial wildcard on the other side.")
    public wildcardPartialSecond() {
        w = new wildy();
        return test.expect(w.f("hi", 1), "*i");
    }

    @Test(name = "(wildcard) All-wildcard catches everything else.")
    public wildcardAll() {
        w = new wildy();
        return test.expect(w.f("a", "b"), "**");
    }

    @Test(name = "(wildcard) Equal-specificity ambiguity raises AMBIGUOUS_OVERLOAD.")
    public wildcardAmbiguity() {
        a = new ambiguous();
        ex = "";
        try { a.f(1, 2); } catch (e) { ex = e.getText(); }
        return test.expect(ex.contains("ambiguous"), true);
    }

    // ---------- Variadic ----------

    @Test(name = "(variadic) Exact two-arg beats variadic on arity-2 call.")
    public variadicExactWins() {
        v = new variadicMix();
        return test.expect(v.f(1, 2), "ii-exact");
    }

    @Test(name = "(variadic) Variadic catches arity-3 call when no exact match.")
    public variadicTrailing() {
        v = new variadicMix();
        return test.expect(v.f(1, 2, 3), "i-variadic-2");
    }

    @Test(name = "(variadic) Typed variadic accepts only declared type.")
    public variadicTypedOk() {
        t = new typedVar();
        return test.expect(t.sum(1, 2, 3), 6);
    }

    @Test(name = "(variadic) Typed variadic rejects mismatched-type arg.")
    public variadicTypedReject() {
        t = new typedVar();
        ex = "";
        try { t.sum(1, "two", 3); } catch (e) { ex = e.getText(); }
        return test.expect(ex != "", true);
    }

    @Test(name = "(variadic) Typed required head plus variadic tail.")
    public variadicTypedHead() {
        h = new headVar();
        return test.expect(h.log("info", "a", "b"), "info:2");
    }

    @Test(name = "(variadic) Typed-head variadic with empty tail.")
    public variadicTypedHeadEmpty() {
        h = new headVar();
        return test.expect(h.log("warn"), "warn:0");
    }

    @Test(name = "(variadic-promotion) Typed double variadic accepts int args.")
    public variadicPromotion() {
        dv = new doubleVar();
        return test.expect(dv.sum(1, 2, 3), 6.0);
    }

    // ---------- Default arguments ----------

    @Test(name = "(default) Default fills in trailing arg.")
    public defaultsTrailing() {
        g = new greeter();
        return test.expect(g.greet("ada"), "hi ada");
    }

    @Test(name = "(default) Two-arg overload still callable with explicit value.")
    public defaultsExplicit() {
        g = new greeter();
        return test.expect(g.greet("ada", "howdy"), "howdy ada");
    }

    @Test(name = "(default) Null default accepts null call.")
    public defaultNullAcceptsNull() {
        n = new nullable();
        return test.expect(n.take(null), "got-null");
    }

    @Test(name = "(default) Null default still accepts declared type.")
    public defaultNullAcceptsTyped() {
        n = new nullable();
        return test.expect(n.take(7), "got-int-7");
    }

    @Test(name = "(default) Null default callable with no args.")
    public defaultNullNoArgs() {
        n = new nullable();
        return test.expect(n.take(), "got-null");
    }

    // ---------- Null matching ----------

    @Test(name = "(null) Null matches string slot.")
    public nullMatchesString() {
        n = new nullMatch();
        return test.expect(n.takeStr(null), "null-string");
    }

    @Test(name = "(null) Null does NOT match int slot.")
    public nullDoesNotMatchInt() {
        n = new nullMatch();
        ex = "";
        try { n.takePrim(null); } catch (e) { ex = e.getText(); }
        return test.expect(ex != "", true);
    }

    // ---------- Inheritance ----------

    @Test(name = "(inheritance) Parent zero-arg inherited when child only adds 2-arg.")
    public inheritedZeroArgKept() {
        cd = new childDrawer();
        return test.expect(cd.draw(), "base-no-args");
    }

    @Test(name = "(inheritance) Child overrides at exact (name, signature).")
    public inheritedOverridden() {
        cd = new childDrawer();
        return test.expect(cd.draw(1, 2), "child-two-ints");
    }

    @Test(name = "(inheritance) Child can add overload at a new signature.")
    public inheritedAddedSig() {
        cd = new childDrawer();
        return test.expect(cd.draw("triangle"), "child-string");
    }

    @Test(name = "(inheritance) Three-level chain dispatches across all ancestors.")
    public inheritedThreeLevel() {
        c3 = new shape3Child();
        return test.expect(
            c3.draw() + "/" + c3.draw(5) + "/" + c3.draw("hi"),
            "gp-no-args/parent-int/child-string");
    }

    // ---------- Constructors ----------

    @Test(name = "(constructor) Zero-arg ctor selected when no args.")
    public ctorZeroArg() {
        p = new point();
        return test.expect(p.x, 0);
    }

    @Test(name = "(constructor) Two-int ctor selected.")
    public ctorTwoInt() {
        p = new point(3, 4);
        return test.expect(p.x + p.y, 7);
    }

    @Test(name = "(constructor) String ctor selected.")
    public ctorString() {
        p = new point("origin");
        return test.expect(p.x, -1);
    }

    @Test(name = "(constructor) Constructor with no matching overload raises.")
    public ctorNoMatch() {
        ex = "";
        try { p = new point(1, 2, 3); } catch (e) { ex = e.getText(); }
        return test.expect(ex != "", true);
    }

    // ---------- Per-overload access modifiers ----------

    @Test(name = "(access) Private overload denies calls from outside the instance.")
    public accessPrivateDenied() {
        p = new privAccess();
        ex = "";
        try { p.f(1); } catch (e) { ex = e.getText(); }
        return test.expect(ex.contains("No access"), true);
    }

    @Test(name = "(access) Public overload at same name remains callable.")
    public accessPublicCallable() {
        p = new privAccess();
        return test.expect(p.f("hi"), "pub:hi");
    }

    @Test(name = "(access) Internal call to private overload succeeds.")
    public accessInternalCall() {
        p = new privAccess();
        return test.expect(p.callPriv(), "priv:1");
    }

    // ---------- Recursive self-call into overloaded method ----------

    @Test(name = "(recursive) Self-call through an overloaded name dispatches identically.")
    public recursiveSelfCall() {
        r = new recursiveOverload();
        return test.expect(r.f(2), "n:n:base");
    }

    // ---------- Wildcard + variadic mixed on same name ----------

    @Test(name = "(mixed) Wildcard wins over variadic when arity matches.")
    public mixedWildcardWins() {
        m = new mixWildVar();
        return test.expect(m.f(1, "x"), "wild:1/x");
    }

    @Test(name = "(mixed) Variadic catches arity below wildcard's range.")
    public mixedVariadicLow() {
        m = new mixWildVar();
        return test.expect(m.f(1), "var:1/0");
    }

    @Test(name = "(mixed) Variadic catches arity above wildcard's range.")
    public mixedVariadicHigh() {
        m = new mixWildVar();
        return test.expect(m.f(1, 2, 3), "var:1/2");
    }

    // ---------- End-to-end multi-overload dispatch ----------

    @Test(name = "(end-to-end) Multiple overloads on one name dispatch by tag.")
    public endToEndDispatch() {
        l = new location();
        return test.expect(
            l.set(1, 2) + "/" + l.set(1.0, 2.0) + "/" + l.set("z") + "/" + l.set(5),
            "int-int/double-double/string/int");
    }
}

/***************************************************************************
 * aunit per-test hooks (@BeforeEach, @AfterEach, @OnTestFail), tag
 * filter (@Test tags="..."), and per-test timeout storage. Lives in its
 * own test class so the hooks and filters under test do not interfere
 * with the surrounding interpreterTests run.
 *
 * Each test loads a tiny helper class via testRunner.loadTestString and
 * either introspects the parsed UnitTest fields or drives the helper
 * class through the full per-test loop with runClassTests. That keeps
 * deliberate failures and hook errors contained inside the inner runner
 * so they cannot pollute this suite's pass/fail counts.
 ***************************************************************************/
@Test(name = "aunit hooks, tags, and timeout")
class aunitHookFilterTests {

    @Before
    public toRunBefore() {
        c.info("Ran unit test @Before function 'toRunBefore()'.");
    }

    @After
    public toRunAfter() {
        c.info("Ran unit test @After function 'toRunAfter()'.");
    }

    /***********************************************************************
     * Per-test hook annotation detection.
     *********************************************************************/

    @Test(name = "(per-test hooks) BeforeEach annotation is detected on parse.")
    public beforeEachAnnotationDetected() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"hookSrc\")\n";
        src = src + "class hookSrcB {\n";
        src = src + "  @BeforeEach public be() { return 0; }\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("hookSrcB", src);
        return test.expect(r.hasBeforeEach("hookSrcB"), true);
    }

    @Test(name = "(per-test hooks) AfterEach annotation is detected on parse.")
    public afterEachAnnotationDetected() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"hookSrc\")\n";
        src = src + "class hookSrcC {\n";
        src = src + "  @AfterEach public ae() { return 0; }\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("hookSrcC", src);
        return test.expect(r.hasAfterEach("hookSrcC"), true);
    }

    @Test(name = "(per-test hooks) OnTestFail annotation is detected on parse.")
    public onTestFailAnnotationDetected() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"hookSrc\")\n";
        src = src + "class hookSrcA {\n";
        src = src + "  @OnTestFail public oh() { return 0; }\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("hookSrcA", src);
        return test.expect(r.hasOnTestFail("hookSrcA"), true);
    }

    @Test(name = "(per-test hooks) Class without per-test hooks reports them as absent.")
    public hooksAbsentByDefault() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"plain\")\n";
        src = src + "class plainSrc {\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("plainSrc", src);
        if (r.hasBeforeEach("plainSrc") != false) { return test.fail("hasBeforeEach should be false"); }
        if (r.hasAfterEach("plainSrc") != false) { return test.fail("hasAfterEach should be false"); }
        if (r.hasOnTestFail("plainSrc") != false) { return test.fail("hasOnTestFail should be false"); }
        return true;
    }

    /***********************************************************************
     * Per-test hook execution. runClassTests drives a loaded class
     * through the full per-test loop. The result map carries
     * total/skipped/passed/failed counts.
     *********************************************************************/

    @Test(name = "(per-test hooks) OnTestFail fires on failing test, not on passing test.")
    public onTestFailFires() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"hookExec\")\n";
        src = src + "class hookExecA {\n";
        src = src + "  public failCount = 0;\n";
        src = src + "  public passCount = 0;\n";
        src = src + "  @OnTestFail public oh() { this.failCount = this.failCount + 1; }\n";
        src = src + "  @AfterEach public ae() { this.passCount = this.passCount + 1; }\n";
        src = src + "  @Test(name = \"good\") public good() { return test.expect(1, 1); }\n";
        src = src + "  @Test(name = \"bad\") public bad() { return test.expect(1, 2); }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("hookExecA", src);
        res = r.runClassTests("hookExecA");
        if (res["passed"] != 1) { return test.fail("expected 1 passed, got " + res["passed"]); }
        if (res["failed"] != 1) { return test.fail("expected 1 failed, got " + res["failed"]); }
        return true;
    }

    @Test(name = "(per-test hooks) BeforeEach throwing fails the test.")
    public beforeEachThrowFails() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"hookExec\")\n";
        src = src + "class hookExecB {\n";
        src = src + "  @BeforeEach public be() { throw \"boom\"; }\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("hookExecB", src);
        res = r.runClassTests("hookExecB");
        return test.expect(res["failed"], 1);
    }

    @Test(name = "(per-test hooks) AfterEach throwing does not flip a passed test.")
    public afterEachThrowDoesNotFail() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"hookExec\")\n";
        src = src + "class hookExecC {\n";
        src = src + "  @AfterEach public ae() { throw \"after-each-boom\"; }\n";
        src = src + "  @Test(name = \"t\") public t() { return test.expect(1, 1); }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("hookExecC", src);
        res = r.runClassTests("hookExecC");
        return test.expect(res["passed"], 1);
    }

    /***********************************************************************
     * Tag parsing.
     *********************************************************************/

    @Test(name = "(test tags) Comma-separated tags parse into a list.")
    public tagsParseList() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"tagSrc\")\n";
        src = src + "class tagSrcA {\n";
        src = src + "  @Test(name = \"t\", tags = \"slow,db\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("tagSrcA", src);
        tags = r.getTestTags("tagSrcA", "t");
        if (#tags != 2) { return test.fail("expected 2 tags, got " + #tags); }
        if (!tags.contains("slow")) { return test.fail("missing 'slow'"); }
        if (!tags.contains("db")) { return test.fail("missing 'db'"); }
        return true;
    }

    @Test(name = "(test tags) Whitespace around tags is trimmed.")
    public tagsTrimmed() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"tagSrc\")\n";
        src = src + "class tagSrcB {\n";
        src = src + "  @Test(name = \"t\", tags = \"  slow  ,  db  \") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("tagSrcB", src);
        tags = r.getTestTags("tagSrcB", "t");
        if (!tags.contains("slow")) { return test.fail("missing trimmed 'slow'"); }
        if (!tags.contains("db")) { return test.fail("missing trimmed 'db'"); }
        return true;
    }

    @Test(name = "(test tags) Missing tags arg yields empty list.")
    public tagsMissingEmpty() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"tagSrc\")\n";
        src = src + "class tagSrcC {\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("tagSrcC", src);
        return test.expect(#r.getTestTags("tagSrcC", "t"), 0);
    }

    /***********************************************************************
     * Tag include/exclude filter via shouldRun().
     *********************************************************************/

    // Helper: a runner with one test tagged "slow".
    public _mkTaggedRunner() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"filt\")\n";
        src = src + "class filtSrc {\n";
        src = src + "  @Test(name = \"t\", tags = \"slow\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("filtSrc", src);
        return r;
    }

    @Test(name = "(test tags) No filter -> tagged test runs.")
    public filterNone() {
        r = this._mkTaggedRunner();
        return test.expect(r.shouldRun("filtSrc", "t"), true);
    }

    @Test(name = "(test tags) Include matching tag -> runs.")
    public filterIncludeMatch() {
        r = this._mkTaggedRunner();
        r.setIncludeTags(["slow"]);
        return test.expect(r.shouldRun("filtSrc", "t"), true);
    }

    @Test(name = "(test tags) Include non-matching tag -> skipped.")
    public filterIncludeNoMatch() {
        r = this._mkTaggedRunner();
        r.setIncludeTags(["fast"]);
        return test.expect(r.shouldRun("filtSrc", "t"), false);
    }

    @Test(name = "(test tags) Exclude matching tag -> skipped.")
    public filterExcludeMatch() {
        r = this._mkTaggedRunner();
        r.setExcludeTags(["slow"]);
        return test.expect(r.shouldRun("filtSrc", "t"), false);
    }

    @Test(name = "(test tags) Exclude wins over include when both match.")
    public filterExcludeWins() {
        r = this._mkTaggedRunner();
        r.setIncludeTags(["slow"]);
        r.setExcludeTags(["slow"]);
        return test.expect(r.shouldRun("filtSrc", "t"), false);
    }

    @Test(name = "(test tags) Untagged test is skipped under any include filter.")
    public filterUntaggedExcludedByInclude() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"untag\")\n";
        src = src + "class untagSrc {\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("untagSrc", src);
        r.setIncludeTags(["fast"]);
        return test.expect(r.shouldRun("untagSrc", "t"), false);
    }

    @Test(name = "(test tags) Untagged test is unaffected by exclude filter.")
    public filterUntaggedUnaffectedByExclude() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"untag2\")\n";
        src = src + "class untag2Src {\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("untag2Src", src);
        r.setExcludeTags(["slow"]);
        return test.expect(r.shouldRun("untag2Src", "t"), true);
    }

    @Test(name = "(test tags) Tag filter excludes via runClassTests.")
    public tagFilterAtRuntime() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"runFilt\")\n";
        src = src + "class runFiltSrc {\n";
        src = src + "  @Test(name = \"fast\", tags = \"fast\") public f() { return 0; }\n";
        src = src + "  @Test(name = \"slow\", tags = \"slow\") public s() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("runFiltSrc", src);
        r.setExcludeTags(["slow"]);
        res = r.runClassTests("runFiltSrc");
        if (res["passed"] != 1) { return test.fail("expected 1 passed, got " + res["passed"]); }
        if (res["skipped"] != 1) { return test.fail("expected 1 skipped, got " + res["skipped"]); }
        return true;
    }

    /***********************************************************************
     * timeoutMs parsing. The base runner does not enforce the value;
     * these tests only verify that the annotation is captured and
     * exposed for a downstream watchdog.
     *********************************************************************/

    @Test(name = "(test timeout) Numeric string parses to long.")
    public timeoutParsesLong() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"toSrc\")\n";
        src = src + "class toSrcA {\n";
        src = src + "  @Test(name = \"t\", timeoutMs = \"2000\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("toSrcA", src);
        return test.expect(r.getTestTimeoutMs("toSrcA", "t"), 2000);
    }

    @Test(name = "(test timeout) Missing arg yields 0.")
    public timeoutMissingZero() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"toSrc\")\n";
        src = src + "class toSrcB {\n";
        src = src + "  @Test(name = \"t\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("toSrcB", src);
        return test.expect(r.getTestTimeoutMs("toSrcB", "t"), 0);
    }

    @Test(name = "(test timeout) Unparseable string yields 0.")
    public timeoutUnparseableZero() {
        src = "include aunit;\n";
        src = src + "@Test(name = \"toSrc\")\n";
        src = src + "class toSrcC {\n";
        src = src + "  @Test(name = \"t\", timeoutMs = \"not-a-number\") public t() { return 0; }\n";
        src = src + "}\n";
        r = new testRunner();
        r.loadTestString("toSrcC", src);
        return test.expect(r.getTestTimeoutMs("toSrcC", "t"), 0);
    }
}