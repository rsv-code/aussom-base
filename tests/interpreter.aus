	public listAdd() { this.tlist.add("one"); return test.expect(#this.tlist, 1); }

	@Test(name = "(lang list) List add all.")
	public listAddAll() { tmp = []; tmp @= "two"; tmp @= "three"; this.tlist.addAll(tmp); return test.expect(#this.tlist, 3); }

	@Test(name = "(lang list) List add all at.")
	public listAddAllAt() { tmp = []; tmp @= "two"; tmp @= "three"; this.tlist.addAllAt(tmp, 1); return test.expect(this.tlist[2], 'three'); }

	@Test(name = "(lang list) List clone.")
