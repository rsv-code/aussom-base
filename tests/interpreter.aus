	public langLangTypeDouble() { return test.expect(lang.type(3.1415), 'double'); }

	@Test(name = "(lang lang) Lang type of string.")
	public langLangTypeString() { return test.expect(lang.type("Austin"), 'string'); }

	@Test(name = "(lang lang) Lang create callback.")
	public langLangCreateCallback() { this.cb = ::toCall; return test.expectCallback(this.cb); }

	@Test(name = "(lang lang) Lang call callback.")
	public langLangCallCallback() { ret = this.cb.call(); return test.expect(ret, true); }

	@Test(name = "(lang lang) Lang create callback with args.")
	public langLangCreateCallbackArgs() { this.cb = ::toCallWithArgs; return test.expectCallback(this.cb); }

	@Test(name = "(lang lang) Lang call callback with args.")
	public langLangCallCallbackArgs() { ret = this.cb.call('hi', 'there'); return test.expect(ret, 'there'); }

	@Test(name = "(lang lang) Lang create callback with etc.")
	public langLangCreateCallbackEtc() { this.cb = ::toCallWithEtc; return test.expectCallback(this.cb); }

	@Test(name = "(lang lang) Lang call callback with etc.")
	public langLangCallCallbackEtc() { ret = this.cb.call('hi', 'there'); return test.expect(ret, 'hi'); }

	@Test(name = "(lang lang) Lang create callback with etc count.")
	public langLangCreateCallbackEtcCnt() { this.cb = ::toCallWithEtcCnt; return test.expectCallback(this.cb); }

	@Test(name = "(lang lang) Lang call callback with etc count.")
	public langLangCallCallbackEtcCnt() { ret = this.cb.call('hi', 'there', 1, 2, 3); return test.expect(ret, 4); }

	@Test(name = "(lang lang) Lang callback member access.")
	public langLangCallbackMemberAcc() {
		this.cb = ::toCallCheckMemb;
		ret = this.cb.call();
		return test.expect(ret, 'callback');
	}

	// Cross-class callback invoked via bare cb() syntax. Owner builds a
	// receiver wired to its own ::onPing; the receiver invokes the stored
	// callback via this.cb() (no .call()). The dispatcher must fall back
	// to invoking the AussomCallback when the name resolves to a member
	// field rather than a class function.
	@Test(name = "(lang lang) Cross-class callback via bare cb() reaches owner.")
	public langLangCallbackBareCallCrossClass() {
		o = new cbOwner();
		r = o.makeReceiver();
		v = r.fireBare();
		return test.expect(v, "result");
	}

	@Test(name = "(lang lang) Cross-class callback via bare cb() mutates owner state.")
	public langLangCallbackBareCallMutatesOwner() {
		o = new cbOwner();
		r = o.makeReceiver();
		r.fireBare();
		return test.expect(o.state, "pinged");
	}

	// callback methods
	public toCall() { return true; }
	public toCallWithArgs(string one, string two) { return two; }
	public toCallWithEtc(string one, ...) { return one; }
	public toCallWithEtcCnt(string one, ...) { return #etc; }
	public toCallCheckMemb() { return lang.type(this.cb); }
	
