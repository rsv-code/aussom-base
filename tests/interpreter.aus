	 /***********************************************************************
      * missing-null tests
      *********************************************************************/
	 @Test(name = "(? operator) Dereference with missing-null.")
	 public dereferenceMissingNull() { val = 'test'; ret = ?val.doesnt.exist; return test.expect(ret, null); }

	 @Test(name = "(? operator) Dereference index expression with missing-null.")
	 public dereferenceMissingNullIndexExp() { val = 'test'; ret = ?val["doesnt"].exist; return test.expect(ret, null); }

     @Test(name = "(? operator) Dereference index expression with missing-null no exception in expression.")
     public dereferenceMissingNullIndexExpNoExcept() {
        ex = true;
        val = {
            name: "Hogan"
        };
        try {
            ?val[val.doesnt.exist];
        } catch (e) {
            ex = false;
        }
        return test.expect(ex, true);
     }

     @Test(name = "(? operator) Dereference index expression with missing-null exception in expression.")
     public dereferenceMissingNullIndexExpExcept() {
        ex = false;
        val = {
            name: "Hogan"
        };
        try {
            ?val[10/0];
        } catch (e) {
            ex = true;
        }
        return test.expect(ex, true);
     }

	 /***********************************************************************
	  * if/else tests
	  *********************************************************************/
	 @Test(name = "(if/else) If/Else statement return true.")
	 public ifElseIfReturnTrue() { return test.expect(this.ifElseReturnTrue(), true); }

	 @Test(name = "(if/else) If/Else statement else return false.")
	 public ifElseElseReturnFalse() { return test.expect(this.ifElseReturnFalse(), false); }
	 public ifElseReturnTrue() {
	 	if(true) { return true; }
	 	else { return false; }
	 }
	 public ifElseReturnFalse() {
	 	if(false) { return true; }
	 	else { return false; }
	 }

	 @Test(name = "(if/else) If/Else statement else if true.")
	 public ifElseElseIfTrue() {
	 	res = null;
	 	if(false) { res = false; }
	 	else if(true) { res = true; }
	 	else { res = false; }
	 	return test.expect(res, true);
	 }

	/***********************************************************************
	  * switch tests
	  *********************************************************************/
	 @Test(name = "(switch) Switch statement case 1.")
	 public switchCase1() {
        val = "one";
        ret = "";
        switch(val) {
            case "one": {
                ret = "one";
            } case "two": {
                ret = "two";
            } default: {
                ret = "def";
            }
        }
        return test.expect(ret, "one");
	 }

	 @Test(name = "(switch) Switch statement case 2.")
	 public switchCase2() {
        val = "two";
        ret = "";
        switch(val) {
            case "one": {
                ret = "one";
            } case "two": {
                ret = "two";
            } default: {
                ret = "def";
            }
        }
        return test.expect(ret, "two");
	 }

	 @Test(name = "(switch) Switch statement default case.")
	 public switchCaseDefault() {
        val = "";
        ret = "";
        switch(val) {
            case "one": {
                ret = "one";
            } case "two": {
                ret = "two";
            } default: {
                ret = "def";
            }
        }
        return test.expect(ret, "def");
	 }

	 /***********************************************************************
	  * loop tests
	  *********************************************************************/
	 @Test(name = "(for/break) Inner and outer for loop with break statement.")
	 public forLoopInnerOuterBreak() {
	    breakSuccess = false;
	    for (i = 0; i < 5; i++) {
	        for (j = 0; j < 5; j++) {
	            break;
	        }
	        breakSuccess = true;
	        break;
	    }
	    return test.expect(breakSuccess, true);
	 }

	 @Test(name = "(for/return) Inside return in for loop.")
	 public forLoopReturn() {
	    return test.expect(this.forLoopTest(), 2);
	 }
	 private forLoopTest() {
	    for (i = 0; i < 5; i++) {
	        if (i == 2) {
	            return i;
	        }
	    }
	 }
	 
