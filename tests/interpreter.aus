	@Test(name = "(lang string) String to upper case.")
	public stringToUpper() { return test.expect("Tyler".toUpper(), "TYLER"); }

	@Test(name = "(lang string) String trim.")
	public stringTrim() { return test.expect(" Tyler ".trim(), "Tyler"); }

	@Test(name = "(lang string) String to JSON.")
