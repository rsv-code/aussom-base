      * missing-null tests
      *********************************************************************/
	 @Test(name = "(? operator) Dereference with missing-null.")
	 public dereferenceMissingNull() { val = 'test'; ret = ?val.doesnt.exist; return test.expect(ret, null); }

	 @Test(name = "(? operator) Dereference index expression with missing-null.")
	 public dereferenceMissingNullIndexExp() { val = 'test'; ret = ?val["doesnt"].exist; return test.expect(ret, null); }

     @Test(name = "(? operator) Dereference index expression with missing-null no exception in expression.")
     public dereferenceMissingNullIndexExpNoExcept() {
        ex = true;
        val = {
            name: "Hogan"
        };
        try {
            ?val[val.doesnt.exist];
        } catch (e) {
            ex = false;
        }
        return test.expect(ex, true);
     }

     @Test(name = "(? operator) Dereference index expression with missing-null exception in expression.")
     public dereferenceMissingNullIndexExpExcept() {
        ex = false;
        val = {
            name: "Hogan"
        };
        try {
            ?val[10/0];
        } catch (e) {
            ex = true;
        }
        return test.expect(ex, true);
     }

	 /***********************************************************************
	  * if/else tests
	  *********************************************************************/
	 @Test(name = "(if/else) If/Else statement return true.")
	 public ifElseIfReturnTrue() { return test.expect(this.ifElseReturnTrue(), true); }

	 @Test(name = "(if/else) If/Else statement else return false.")
	 public ifElseElseReturnFalse() { return test.expect(this.ifElseReturnFalse(), false); }
	 public ifElseReturnTrue() {
	 	if(true) { return true; }
	 	else { return false; }
	 }
	 public ifElseReturnFalse() {
	 	if(false) { return true; }
	 	else { return false; }
	 }

	 @Test(name = "(if/else) If/Else statement else if true.")
	 public ifElseElseIfTrue() {
	 	res = null;
	 	if(false) { res = false; }
	 	else if(true) { res = true; }
	 	else { res = false; }
	 	return test.expect(res, true);
	 }

	/***********************************************************************
	  * switch tests
	  *********************************************************************/
	 @Test(name = "(switch) Switch statement case 1.")
	 public switchCase1() {
        val = "one";
        ret = "";
        switch(val) {
            case "one": {
                ret = "one";
            } case "two": {
                ret = "two";
            } default: {
                ret = "def";
            }
        }
        return test.expect(ret, "one");
	 }

	 @Test(name = "(switch) Switch statement case 2.")
	 public switchCase2() {
        val = "two";
        ret = "";
        switch(val) {
            case "one": {
                ret = "one";
            } case "two": {
                ret = "two";
            } default: {
                ret = "def";
            }
        }
        return test.expect(ret, "two");
	 }

	 @Test(name = "(switch) Switch statement default case.")
	 public switchCaseDefault() {
        val = "";
        ret = "";
        switch(val) {
            case "one": {
                ret = "one";
            } case "two": {
                ret = "two";
            } default: {
                ret = "def";
            }
        }
        return test.expect(ret, "def");
	 }

	 @Test(name = "(switch) Switch case type mismatch caught by surrounding try/catch.")
	 public switchTypeMismatchCaught() {
	    thrown = false;
	    try {
	        // The switch value is an int but the cases are strings. The
	        // type-mismatch error must be catchable by the surrounding
	        // try/catch block.
	        val = 5;
	        switch (val) {
	            case "one": { c.println("one"); }
	            case "two": { c.println("two"); }
	            default: { c.println("def"); }
	        }
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(switch) Default body exception caught by surrounding try/catch.")
	 public switchDefaultBodyExceptionCaught() {
	    thrown = false;
	    try {
	        // A statement in the default block throws. The exception must
	        // propagate out of the switch and be caught here, not silently
	        // swallowed by the default-block iteration.
	        x = "no_match";
	        switch (x) {
	            case "a": { c.println("a"); }
	            default: {
	                throwingHelper.boom();
	                c.println("never");
	            }
	        }
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 /***********************************************************************
	  * loop tests
	  *********************************************************************/
	 @Test(name = "(for/break) Inner and outer for loop with break statement.")
	 public forLoopInnerOuterBreak() {
	    breakSuccess = false;
	    for (i = 0; i < 5; i++) {
	        for (j = 0; j < 5; j++) {
	            break;
	        }
	        breakSuccess = true;
	        break;
	    }
	    return test.expect(breakSuccess, true);
	 }

	 @Test(name = "(for/return) Inside return in for loop.")
	 public forLoopReturn() {
	    return test.expect(this.forLoopTest(), 2);
	 }
	 private forLoopTest() {
	    for (i = 0; i < 5; i++) {
	        if (i == 2) {
	            return i;
	        }
	    }
	 }

	 @Test(name = "(foreach) Non-iterable target caught by surrounding try/catch.")
	 public foreachNonIterableCaught() {
	    thrown = false;
	    try {
	        // The foreach target is an int (not a list or map). The
	        // type error must be catchable by the surrounding try/catch.
	        for (item : 5) {
	            c.println("never");
	        }
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(for) C-style condition exception caught by surrounding try/catch.")
	 public forConditionExceptionCaught() {
	    thrown = false;
	    try {
	        // The condition expression of a C-style for loop throws.
	        // The exception must be catchable by the surrounding try/catch.
	        for (i = 0; throwingHelper.boom(); i++) {
	            c.println("never");
	        }
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(while) Condition exception caught by surrounding try/catch.")
	 public whileConditionExceptionCaught() {
	    thrown = false;
	    try {
	        // The condition expression of a while loop throws. The
	        // exception must be catchable by the surrounding try/catch.
	        while (throwingHelper.boom()) {
	            c.println("never");
	        }
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

	 @Test(name = "(while) Body exception caught by surrounding try/catch.")
	 public whileBodyExceptionCaught() {
	    thrown = false;
	    try {
	        // A statement in the while body throws. The exception must
	        // propagate out of the loop and be caught here, not silently
	        // swallowed by the loop iteration.
	        i = 0;
	        while (i < 1) {
	            throwingHelper.boom();
	            i = i + 1;
	        }
	    } catch (e) {
	        thrown = true;
	    }
	    return test.expect(thrown, true);
	 }

